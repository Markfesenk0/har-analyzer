HAR_ANALYZER_LLM_PROVIDER=deepinfra
HAR_ANALYZER_LLM_BASE_URL=https://api.deepinfra.com/v1/openai
HAR_ANALYZER_LLM_API_KEY=YOUR_DEEPINFRA_API_KEY_HERE
# Hypothesis generation model (needs low refusal for security content)
HAR_ANALYZER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
# Finding validation model (can be cheaper, just compares JSON)
HAR_ANALYZER_VALIDATION_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507

HAR_ANALYZER_REDACT_BY_DEFAULT=false
HAR_ANALYZER_UNSAFE_UNREDACTED_DEFAULT=false
HAR_ANALYZER_MAX_BODY_CHARS=4000
HAR_ANALYZER_TRUNCATED_BODY_CHARS=1000
HAR_ANALYZER_NEIGHBOR_CONTEXT_WINDOW=2
HAR_ANALYZER_LLM_TIMEOUT_SECONDS=60

# Token Injection: Replace outdated HAR tokens with fresh ones during testing
# Useful when HAR file contains expired JWT/cookies that need refreshing
HAR_ANALYZER_AUTH_TOKEN=Bearer YOUR_FRESH_JWT_TOKEN_HERE
